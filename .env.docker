# Agent Orchestrator - Docker environment variables
# Copy this file to .env and adjust as needed:
#   cp .env.docker .env

# ---- Web Dashboard ----
# Host port for the Next.js dashboard
WEB_PORT=3000

# Terminal WebSocket server ports
TERMINAL_PORT=14800
DIRECT_TERMINAL_PORT=14801

# Public env vars exposed to the browser (match the ports above)
NEXT_PUBLIC_TERMINAL_PORT=14800
NEXT_PUBLIC_DIRECT_TERMINAL_PORT=14801

# ---- General ----
NODE_ENV=development
