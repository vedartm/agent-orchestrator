# Agent Orchestrator - Docker environment variables
# Copy this file to .env and adjust as needed:
#   cp .env.docker .env

# ---- Web Dashboard ----
# Host port for the Next.js dashboard
WEB_PORT=3000

# Terminal WebSocket server ports (browser NEXT_PUBLIC_* vars are derived from these)
TERMINAL_PORT=14800
DIRECT_TERMINAL_PORT=14801

# ---- General ----
NODE_ENV=development
